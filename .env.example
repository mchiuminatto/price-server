DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/priceserver
DEBUG=false
ASYNC_EXPORT_DIR=/tmp/exports
MAX_UPLOAD_SIZE_MB=100

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_REDIS_URL=redis://localhost:6379/0
PIPELINE_STORAGE_BACKEND=local         # local | s3
PIPELINE_INPUT_BASE_PATH=/data/raw
PIPELINE_OUTPUT_BASE_PATH=/data/processed
PIPELINE_WORKER_COUNT=2

# AWS (only required when PIPELINE_STORAGE_BACKEND=s3)
PIPELINE_AWS_ACCESS_KEY_ID=
PIPELINE_AWS_SECRET_ACCESS_KEY=
PIPELINE_AWS_SESSION_TOKEN=
PIPELINE_AWS_REGION=us-east-1
